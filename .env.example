# CA Activity Visibility — example of the keys this project needs.
# This file has NO real values and is safe to share / upload.
# To use it: copy this file to a new file named ".env", then fill in the real values there.

# AmpleMarket key (from Ray)
AMPLEMARKET_API_KEY=

# HubSpot key (from Ray / HubSpot admin)
HUBSPOT_PRIVATE_APP_TOKEN=

# Supabase storage — web address (from the Supabase project settings page)
SUPABASE_URL=

# Supabase storage — access key (from the Supabase project settings page)
SUPABASE_KEY=

# Supabase database connection string (Connect -> Transaction pooler -> URI)
# Used by the ingestion job to create tables and write data.
SUPABASE_DB_URL=
